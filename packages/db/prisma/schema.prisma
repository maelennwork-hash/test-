generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum ContactStatus {
  ACTIVE
  INACTIVE
}

enum LeadStage {
  NEW_LEAD
  CONTACTED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum InteractionType {
  NOTE
  CALL
  MEETING
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts      Contact[]
  leads         Lead[]
  interactions  Interaction[]
  activities    Activity[]
  notifications Notification[]
}

model Contact {
  id        String        @id @default(cuid())
  ownerId   String
  owner     User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name      String
  company   String?
  email     String?
  phone     String?
  status    ContactStatus @default(ACTIVE)
  notes     String?

  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tags        ContactTag[]
  leads       Lead[]
  interactions Interaction[]
}

model Tag {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  contacts  ContactTag[]

  @@unique([ownerId, name])
}

model ContactTag {
  contactId String
  tagId     String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

model Lead {
  id         String    @id @default(cuid())
  ownerId    String
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  title      String
  valueCents Int       @default(0)
  stage      LeadStage @default(NEW_LEAD)
  position   Int       @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([ownerId, stage, position])
}

model Interaction {
  id         String          @id @default(cuid())
  ownerId    String
  owner      User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)

  type       InteractionType
  summary    String
  occurredAt DateTime        @default(now())
  followUpAt DateTime?

  createdAt  DateTime        @default(now())

  @@index([ownerId, contactId, occurredAt])
}

model Notification {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  type        String
  title       String
  body        String?
  scheduledAt DateTime
  sentAt      DateTime?
  status      String   @default("PENDING")
  error       String?

  createdAt   DateTime @default(now())

  @@index([ownerId, scheduledAt, status])
}

model Activity {
  id         String   @id @default(cuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  type       String
  entityId   String?
  entityType String?
  message    String
  createdAt  DateTime @default(now())

  @@index([ownerId, createdAt])
}

